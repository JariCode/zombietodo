# ================================
# .htaccess — Turvapoikkeamat
# ================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    #########################################################
    # 1) SALLI actions.php:
    #    - POST-pyynnöt (lomakkeet ja AJAX)
    #    - Estä GET-pyynnöt kokonaan
    #########################################################
    RewriteCond %{REQUEST_METHOD} ^POST$
    RewriteRule ^app/actions\.php$ - [L]

    RewriteCond %{REQUEST_METHOD} ^GET$
    RewriteCond %{HTTP_ACCEPT} text/html
    RewriteRule ^app/actions\.php$ - [F,L]

    #########################################################
    # 2) ESTÄ partial-tasks.php suora selainpyyntö
    #########################################################
    RewriteCond %{HTTP_ACCEPT} text/html
    RewriteCond %{THE_REQUEST} \.php
    RewriteRule ^app/partial-tasks\.php$ - [F,L]

    RewriteCond %{HTTP_ACCEPT} text/html
    RewriteCond %{THE_REQUEST} \.php
    RewriteRule ^app/partial-admin\.php$ - [F,L]

    #########################################################
    # 3) ESTÄ muut app/-kansion PHP-tiedostot selaimelta
    #########################################################
    RewriteCond %{HTTP_ACCEPT} text/html
    RewriteCond %{THE_REQUEST} \.php
    RewriteRule ^app/.*\.php$ - [F,L]

</IfModule>

#########################################################
# 4) Estä .env aina
#########################################################
<Files ".env">
    Require all denied
</Files>

#########################################################
# 5) Estä .htaccess itse
#########################################################
<Files ".htaccess">
    Require all denied
</Files>

#########################################################
# 6) Estä db.php suora HTTP-pyyntö
#########################################################
<Files "db.php">
    Require all denied
</Files>

#########################################################
# 7) HTTP-turvaheaderit
#########################################################
<IfModule mod_headers.c>
    Header unset X-Frame-Options
    Header always set X-Frame-Options "DENY"

    Header unset X-Content-Type-Options
    Header always set X-Content-Type-Options "nosniff"

    Header unset Referrer-Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    Header unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'"

    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Cross-Origin-Opener-Policy "same-origin"

    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), autoplay=()"

    <FilesMatch "\.js$">
        Header set Content-Type "application/javascript; charset=UTF-8"
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.css$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>